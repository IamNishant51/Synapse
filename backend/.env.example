# Backend config — Synapse Cognee
# Primary: Google Gemini (free tier, robust JSON schema tool-calling for Cognee)
# Fallback: Groq Native (OpenAI-compatible endpoint)
LLM_PROVIDER=gemini
LLM_MODEL=gemini/gemini-2.5-flash
GEMINI_API_KEY=your-gemini-api-key-here

# Groq fallback config
GROQ_API_KEY=your-groq-api-key-here
LLM_MODEL_FALLBACK=groq/llama-3.3-70b-versatile

# Access control — REQUIRED in any deployed environment.
# If unset, the backend fails closed (see main.py's verify_access_key).
SYNAPSE_ACCESS_KEY=generate-a-long-random-string-here

# Optional: Dedicated judge access token for WeMakeDevs × Cognee Hackathon.
# If configured, judges can paste this string to run on pre-funded server LLM keys.
JUDGE_ACCESS_TOKEN=SYNAPSE-JUDGE-efd63f63d6f5b7842f89a9ab0b46dcc9

# The deployed frontend's exact origin — used for CORS allow-origins.
FRONTEND_URL=http://localhost:3000

MOCK_EMBEDDING=true
COGNEE_SKIP_CONNECTION_TEST=true

