# Backend config — Synapse Cognee
# Primary LLM provider
LLM_PROVIDER=gemini
LLM_MODEL=gemini/gemini-2.5-flash
GEMINI_API_KEY=your_gemini_key_here

# Fallback LLM provider (optional)
GROQ_API_KEY=your_groq_key_here
LLM_MODEL_FALLBACK=groq/llama-3.3-70b-versatile

# Shared access key (must match frontend SYNAPSE_ACCESS_KEY)
SYNAPSE_ACCESS_KEY=change-me-in-production

# Encryption key for BYOK API keys at rest
# Generate with: openssl rand -base64 32
SYNAPSE_ENCRYPTION_KEY=your_encryption_key_here

# Token for internal judge LLM calls
JUDGE_ACCESS_TOKEN=your_token_here

# Database — PostgreSQL connection string (required on Vercel)
# Vercel Postgres sets this automatically via POSTGRES_URL
DATABASE_URL=

# Cognee config
MOCK_EMBEDDING=true
COGNEE_SKIP_CONNECTION_TEST=true
ENVIRONMENT=development

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000
