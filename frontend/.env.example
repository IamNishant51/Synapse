# Backend URL
# NEXT_PUBLIC_COGNEE_API_URL=http://localhost:8000
# COGNEE_API_URL=http://localhost:8000

# Shared access key (must match backend SYNAPSE_ACCESS_KEY)
# SYNAPSE_ACCESS_KEY=change-me-in-production

# Auth.js v5 — required for session encryption
# Generate with: openssl rand -base64 32
# AUTH_SECRET=generate_a_random_secret_here

# OAuth providers (GitHub, Google)
# AUTH_GITHUB_ID=your_github_oauth_client_id
# AUTH_GITHUB_SECRET=your_github_oauth_client_secret
# AUTH_GOOGLE_ID=your_google_oauth_client_id
# AUTH_GOOGLE_SECRET=your_google_oauth_client_secret
