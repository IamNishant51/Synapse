# Frontend Production Environment Variables
# Copy this file to .env.production (for Vercel preview/production builds)
# or to .env.local (for local dev with `NEXT_PUBLIC_COGNEE_API_URL` set)
# DO NOT COMMIT actual secrets

# Your deployed Vercel URL
NEXT_PUBLIC_APP_URL=https://synapse-knowledge.vercel.app

# NOT needed on Vercel — the API proxy (/api/proxy/[...path]) auto-detects the backend.
# Only set if running frontend standalone (e.g. local dev pointing to a remote backend)
# NEXT_PUBLIC_COGNEE_API_URL=

# Shared access key (must match backend SYNAPSE_ACCESS_KEY)
SYNAPSE_ACCESS_KEY=your-production-access-key-here

# Auth.js v5 — required for session encryption
# Generate with: openssl rand -base64 32
AUTH_SECRET=generate_a_random_secret_here

# OAuth providers (GitHub, Google) — set these in GitHub/Google OAuth apps
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Feature Flags
NEXT_PUBLIC_ENABLE_GRAPH_3D=true
NEXT_PUBLIC_ENABLE_ANIMATIONS=true
